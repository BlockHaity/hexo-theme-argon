<% if (theme.giscus.use_custom_theme) { %>
<link id="giscus-theme-stylesheet" rel="stylesheet" href="/giscus/light.css">
<% } %>
<div id="giscus"></div>
<script>
  const giscusConfig = {
    repo: "<%= theme.giscus.repo %>",
    repoId: "<%= theme.giscus.repo_id %>",
    category: "<%= theme.giscus.category %>",
    categoryId: "<%= theme.giscus.category_id %>",
    mapping: "<%= theme.giscus.mapping %>",
    inputPosition: "<%= theme.giscus.input_position %>",
    lang: "<%= theme.giscus.lang %>",
    loading: "<%= theme.giscus.loading %>",
    useCustomTheme: <%= theme.giscus.use_custom_theme !== false %>,
    lightTheme: "<%= theme.giscus.light_theme || 'light' %>",
    darkTheme: "<%= theme.giscus.dark_theme || 'dark' %>"
  };

  function getGiscusTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('darkmode') || html.classList.contains('dark');
    const isAmoled = html.classList.contains('amoled-dark');

    if (isAmoled) {
      return giscusConfig.darkTheme;
    } else if (isDark) {
      return giscusConfig.darkTheme;
    } else {
      return giscusConfig.lightTheme;
    }
  }

  function updateGiscusTheme() {
    const theme = getGiscusTheme();

    // Update custom CSS if enabled
    if (giscusConfig.useCustomTheme) {
      const stylesheet = document.getElementById('giscus-theme-stylesheet');
      const html = document.documentElement;
      const isDark = html.classList.contains('darkmode') || html.classList.contains('dark');

      if (isDark) {
        stylesheet.href = "/giscus/dark.css";
      } else {
        stylesheet.href = "/giscus/light.css";
      }
    }

    // Update Giscus iframe theme
    const iframe = document.querySelector('#giscus iframe');
    if (iframe) {
      iframe.contentWindow.postMessage({
        giscus: {
          setConfig: {
            theme: theme
          }
        }
      }, 'https://giscus.app');
    }
  }

  function loadGiscus() {
    const old = document.querySelector('#giscus script');
    if (old) old.remove();

    const script = document.createElement('script');
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", giscusConfig.repo);
    script.setAttribute("data-repo-id", giscusConfig.repoId);
    script.setAttribute("data-category", giscusConfig.category);
    script.setAttribute("data-category-id", giscusConfig.categoryId);
    script.setAttribute("data-mapping", giscusConfig.mapping);
    script.setAttribute("data-input-position", giscusConfig.inputPosition);
    script.setAttribute("data-theme", getGiscusTheme());
    script.setAttribute("data-lang", giscusConfig.lang);
    script.setAttribute("data-loading", giscusConfig.loading);
    script.async = true;
    script.crossOrigin = "anonymous";

    document.getElementById("giscus").appendChild(script);

    // Load appropriate CSS based on current theme if using custom theme
    if (giscusConfig.useCustomTheme) {
      updateGiscusTheme();
    }
  }

  loadGiscus();

  document.addEventListener('pjax:end', () => {
    loadGiscus();
  });

  // Listen for theme changes
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'class') {
        const html = document.documentElement;
        const isDark = html.classList.contains('darkmode') || html.classList.contains('dark');
        updateGiscusTheme();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class']
  });
</script>
